# ┌─────────────────────────────────────────────────────────┐
# │  NexDrive — Environment Configuration Example          │
# │  Copy this file to .env and fill in real values.       │
# └─────────────────────────────────────────────────────────┘

# API Gateway Port
PORT_GATEWAY=5000

# Microservice Ports
PORT_ADMIN=6000
PORT_RECLAMATION=6001
PORT_CAR=6002
PORT_BOOKING=6003
PORT_USER=6004
PORT_TELEMETRY=6005
PORT_DEVICE=6006
PORT_NOTIFICATION=6007

# Microservice URLs (used by gateway proxy)
ADMIN_SERVICE=http://localhost:6000
RECLAMATION_SERVICE=http://localhost:6001
CAR_SERVICE=http://localhost:6002
BOOKING_SERVICE=http://localhost:6003
USER_SERVICE=http://localhost:6004
TELEMETRY_SERVICE=http://localhost:6005
DEVICE_SERVICE=http://localhost:6006
NOTIFICATION_SERVICE=http://localhost:6007

# Database URIs (each service owns its own database)
MONGO_URI_ADMIN=mongodb://localhost:27017/admindb
MONGO_URI_RECLAMATION=mongodb://localhost:27017/reclamationdb
MONGO_URI_CAR=mongodb://localhost:27017/cardb
MONGO_URI_BOOKING=mongodb://localhost:27017/bookingdb
MONGO_URI_USER=mongodb://localhost:27017/userdb
MONGO_URI_TELEMETRY=mongodb://localhost:27017/telemetrydb
MONGO_URI_DEVICE=mongodb://localhost:27017/devicedb
MONGO_URI_NOTIFICATION=mongodb://localhost:27017/notificationdb

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_STRONG_RANDOM_STRING
JWT_REFRESH_EXPIRATION=7d

# Device JWT (for IoT device authentication)
DEVICE_JWT_SECRET=CHANGE_ME_DEVICE_SECRET
DEVICE_JWT_EXPIRATION=1h

# Gateway Internal Secret (defense-in-depth)
GATEWAY_SECRET=CHANGE_ME_GATEWAY_INTERNAL_KEY

# Internal Service-to-Service Secret (HMAC)
INTERNAL_S2S_SECRET=CHANGE_ME_S2S_SECRET

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Telemetry service → Device service client
DEVICE_SERVICE_URL=http://localhost:6006
DEVICE_CLIENT_TIMEOUT=3000
DEVICE_CLIENT_RETRIES=2
