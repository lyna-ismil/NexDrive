# Telemetry / IoT Ingestion Service
MONGO_URI_TELEMETRY=mongodb://localhost:27017/telemetrydb
PORT_TELEMETRY=6005

# JWT (admin auth verification)
JWT_SECRET=yourSuperSecretKey

# Device JWT (verify tokens issued by Device service)
DEVICE_JWT_SECRET=deviceSuperSecretKey

# Device service resilient client
DEVICE_SERVICE_URL=http://localhost:6006
DEVICE_CLIENT_TIMEOUT=3000
DEVICE_CLIENT_RETRIES=2
